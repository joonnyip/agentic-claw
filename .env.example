# ============================================================
#  AGENTIC CLAW — Environment Configuration
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=3747

# ── Polymarket ────────────────────────────────────────────
# Public API (market data — no key needed)
POLYMARKET_API=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com

# For live trading (leave blank to use simulation mode)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_ADDRESS=
POLYMARKET_API_KEY=

# ── Mirofish AI ───────────────────────────────────────────
MIROFISH_API=https://api.mirofish.ai/v1
MIROFISH_API_KEY=

# ── Trading Mode ──────────────────────────────────────────
# true  = simulate all trades (safe, default)
# false = live trades on Polymarket (requires keys above)
SIMULATE_TRADES=true

# ── Safety limit ─────────────────────────────────────────
MAX_TRADE_SIZE_USDC=100

# ── Etherscan (Ethereum wallet balance) ───────────────────
# Free key at: https://etherscan.io/apis
ETHERSCAN_API_KEY=
