+// ── Portfolio P&L chart (v2.3) ───────────────────────────────
+let pnlRange = '7d';
+let pnlPoints = [];
+let pnlFetchTimer = null;
+
+function setPnlRange(range) {
+  if (!['7d','30d','90d'].includes(range) || range === pnlRange) return;
+  pnlRange = range;
+  document.querySelectorAll('.pnl-rbtn').forEach(b => {
+    b.classList.toggle('pnl-rbtn-active', b.dataset.range === range);
+  });
+  fetchPnlHistory();
+}
+
+async function fetchPnlHistory() {
+  try {
+    const res = await fetch(`/api/pnl/history?range=${pnlRange}`);
+    const j = await res.json();
+    pnlPoints = j.points || [];
+    drawPnlChart();
+  } catch (e) {
+    // silent — if the endpoint is unreachable the chart just stays empty
+  }
+}
+
+function drawPnlChart() {
+  const canvas = document.getElementById('pnl-canvas');
+  const empty  = document.getElementById('pnl-empty');
+  const delta  = document.getElementById('pnl-delta');
+  if (!canvas || !empty) return;
+
+  // Need at least 2 points to draw a line
+  if (pnlPoints.length < 2) {
+    canvas.style.display = 'none';
+    empty.style.display  = 'block';
+    delta.textContent = '--';
+    delta.className = 'sec-n';
+    return;
+  }
+  canvas.style.display = 'block';
+  empty.style.display  = 'none';
+
+  const ctx = canvas.getContext('2d');
+  const W = canvas.width  = canvas.offsetWidth;
+  const H = canvas.height = 90;
+  ctx.clearRect(0, 0, W, H);
+
+  // Extract balance series
+  const vals = pnlPoints.map(p => Number(p.total_balance) || 0);
+  const min  = Math.min(...vals);
+  const max  = Math.max(...vals);
+  const pad  = 6;                 // vertical padding
+  const range = max - min || 1;   // guard against flat line → div/0
+
+  // Color: green if last > first, red if below
+  const firstV = vals[0], lastV = vals[vals.length - 1];
+  const up     = lastV >= firstV;
+  const stroke = up ? '#00ff9d' : '#ff3366';
+  const fill   = up ? 'rgba(0,255,157,.08)' : 'rgba(255,51,102,.08)';
+
+  // Grid
+  ctx.strokeStyle = 'rgba(26,40,64,.5)';
+  ctx.lineWidth = 1;
+  for (let i = 1; i <= 3; i++) {
+    const y = (H - 2 * pad) * i / 4 + pad;
+    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
+  }
+
+  // Line path
+  const x = i => (i / (vals.length - 1)) * W;
+  const y = v => H - pad - ((v - min) / range) * (H - 2 * pad);
+
+  // Fill area under line
+  ctx.beginPath();
+  ctx.moveTo(0, H);
+  vals.forEach((v, i) => { i === 0 ? ctx.lineTo(x(i), y(v)) : ctx.lineTo(x(i), y(v)); });
+  ctx.lineTo(W, H);
+  ctx.closePath();
+  ctx.fillStyle = fill;
+  ctx.fill();
+
+  // Line
+  ctx.beginPath();
+  vals.forEach((v, i) => { i === 0 ? ctx.moveTo(x(i), y(v)) : ctx.lineTo(x(i), y(v)); });
+  ctx.strokeStyle = stroke;
+  ctx.lineWidth = 1.5;
+  ctx.stroke();
+
+  // Last-point dot
+  ctx.beginPath();
+  ctx.arc(x(vals.length - 1), y(lastV), 3, 0, Math.PI * 2);
+  ctx.fillStyle = stroke;
+  ctx.fill();
+
+  // Update delta badge in section header
+  const d = lastV - firstV;
+  const pct = firstV !== 0 ? (d / Math.abs(firstV)) * 100 : 0;
+  delta.textContent = `${d >= 0 ? '+' : ''}$${d.toFixed(2)} (${pct >= 0 ? '+' : ''}${pct.toFixed(1)}%)`;
+  delta.className = 'sec-n ' + (up ? 'pnl-up' : 'pnl-dn');
+}
+
+// Kick off first fetch ~2s after load (give server time to take its first snapshot)
+// then refresh every 60s — matches the server-side sampler cadence
+setTimeout(fetchPnlHistory, 2000);
+setInterval(fetchPnlHistory, 60000);
+
+// Redraw on resize so the chart fits the column width
+window.addEventListener('resize', drawPnlChart);
